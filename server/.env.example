NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# Auth
JWT_ACCESS_SECRET=replace_me_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_me_with_64_char_random_hex
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_SALT_ROUNDS=12
SEED_USER_PASSWORD=User@1234
SEED_ADMIN_PASSWORD=Admin@1234

# Razorpay
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# Email (Brevo / SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=replace_me@smtp-brevo.com
SMTP_PASS=replace_me
MAIL_FROM="YourAppName <orders@your-domain.com>"

# Security / Operations
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOG_LEVEL=info
